  POUSIO
}

/// Fazenda / propriedade rural do produtor. Base para talhões, carbono, CPR e score.
model Farm {
  id           String          @id @default(uuid())
  userId       String
  name         String
  carNumero    String?         // Cadastro Ambiental Rural
  state        BrazilianState
  city         String
  totalAreaHa  Decimal         @db.Decimal(12, 2)
