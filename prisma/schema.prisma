// ──────────────────────────────────────────────
// MARKETPLACE — PEDIDOS COM CUSTÓDIA (ESCROW) via ValsaPay
// ──────────────────────────────────────────────

enum MarketplaceOrderStatus {
  AGUARDANDO_PAGAMENTO // pedido criado, aguardando pagamento do comprador
  PAGO_EM_CUSTODIA     // pago; ConectCampo retém o valor (escrow)
  ENVIADO              // vendedor marcou como enviado/entregue
  RECEBIDO_LIBERADO    // comprador confirmou recebimento; valor liberado ao vendedor
  REPASSADO            // repasse ao vendedor concluído
  CANCELADO            // cancelado antes do pagamento
  DISPUTA              // comprador abriu disputa
  REEMBOLSADO          // valor devolvido ao comprador
}

/// Pedido de compra/venda no marketplace com custódia do valor pela plataforma.
/// Fluxo: comprador paga (ValsaPay) → ConectCampo retém → vendedor envia →
/// comprador confirma → valor liberado ao vendedor. Taxa ConectCampo: 1% (0,5% cada parte).
model MarketplaceOrder {
  id             String                 @id @default(uuid())
  listingId      String
  buyerId        String
  sellerId       String

  // Snapshot do produto no momento da compra
  product        String
  quantity       Decimal                @db.Decimal(12, 2)
  unit           String
  unitPrice      Decimal                @db.Decimal(12, 2)

  // Valores financeiros (BRL)
  subtotal       Decimal                @db.Decimal(15, 2) // unitPrice * quantity
  buyerFee       Decimal                @db.Decimal(15, 2) // 0,5% do subtotal
  sellerFee      Decimal                @db.Decimal(15, 2) // 0,5% do subtotal
  platformFee    Decimal                @db.Decimal(15, 2) // 1% total (buyerFee + sellerFee)
  buyerTotal     Decimal                @db.Decimal(15, 2) // subtotal + buyerFee (o que o comprador paga)
  sellerNet      Decimal                @db.Decimal(15, 2) // subtotal - sellerFee (o que o vendedor recebe)

  status         MarketplaceOrderStatus @default(AGUARDANDO_PAGAMENTO)

  // Pagamento (ValsaPay)
  paymentUrl     String?
  valsaPaymentId String?

  // Rastreamento / observações
  shippingInfo   String?
  buyerNote      String?
  disputeReason  String?

  // Timestamps do ciclo
  paidAt         DateTime?
  shippedAt      DateTime?
  confirmedAt    DateTime?
  payoutAt       DateTime?
  cancelledAt    DateTime?

  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  listing        GrainListing           @relation(fields: [listingId], references: [id])
  buyer          User                   @relation("OrderBuyer", fields: [buyerId], references: [id])
  seller         User                   @relation("OrderSeller", fields: [sellerId], references: [id])
  reviews        MarketplaceReview[]
  events         MarketplaceOrderEvent[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
  @@index([status])
  @@map("marketplace_orders")
}

/// Trilha de eventos (auditoria) de um pedido do marketplace.
model MarketplaceOrderEvent {
  id          String   @id @default(uuid())
  orderId     String
  type        String   // CRIADO, PAGO, ENVIADO, CONFIRMADO, DISPUTA, REPASSADO, REEMBOLSADO, CANCELADO
  description String
  actorId     String?  // usuário que gerou o evento (null = sistema)
  createdAt   DateTime @default(now())

  order       MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("marketplace_order_events")
}

/// Alerta de preço de commodity criado pelo usuário.
model PriceAlert {
  id        String   @id @default(uuid())
  userId    String
  symbol    String   // SOJA, MILHO, BOI, DOLAR...
  direction String   // ABOVE | BELOW
  target    Decimal  @db.Decimal(12, 2)
  active    Boolean  @default(true)
  triggeredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([symbol])
  @@map("price_alerts")
}

/// Avaliação (reputação) entre comprador e vendedor após um pedido concluído.
model MarketplaceReview {
  id        String   @id @default(uuid())
  orderId   String
  raterId   String   // quem avaliou
  ratedId   String   // quem foi avaliado
  raterRole String   // 'BUYER' | 'SELLER' (papel de quem avaliou no pedido)
  rating    Int      // 1..5
  comment   String?

  createdAt DateTime @default(now())

  order     MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rater     User             @relation("ReviewRater", fields: [raterId], references: [id])
  rated     User             @relation("ReviewRated", fields: [ratedId], references: [id])

  @@unique([orderId, raterId]) // uma avaliação por parte por pedido
  @@index([ratedId])
  @@map("marketplace_reviews")
}

