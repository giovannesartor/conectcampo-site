model CprDocument {
  id                  String      @id @default(uuid())
  userId              String
  producerProfileId   String?

  // Identificação
  numeroCpr           String?     @unique // número sequencial ao registrar
  purpose             CprPurpose
  type                CprType     @default(FINANCEIRA)
  status              CprStatus   @default(RASCUNHO)

  // Emitente (produtor rural)
  emitenteNome        String
  emitenteCpfCnpj     String
  emitenteEndereco    String?
  emitenteCidade      String?
  emitenteEstado      BrazilianState?
  emitenteCarNumero   String?     // número CAR
  emitenteEmail       String?     // para envio automático do link (ZapSign)
  emitenteTelefone    String?     // DDD + número, p/ WhatsApp (ZapSign)

  // Credor (instituição financeira ou pessoa que recebe)
  credorNome          String
  credorCpfCnpj       String
  credorTipo          String?     // banco, cooperativa, pessoa fisica, etc.
  credorEmail         String?
  credorTelefone      String?

  // Produto / garantia
  produto             String      // soja, milho, boi gordo, etc.
  quantidade          Decimal     @db.Decimal(15, 4)
  unidade             String      // sacas, toneladas, arrobas, etc.
  safraAno            String?     // ex: "2025/2026"
  precoUnitario       Decimal?    @db.Decimal(10, 2)
  valorTotal          Decimal?    @db.Decimal(15, 2)
  localEntrega        String?
  dataEntrega         DateTime?

  // Vencimento
  dataVencimento      DateTime
  prazoMeses          Int?
  carenciaMeses       Int?        // carência (máx. 60 meses / 5 anos)

  // Garantia adicional (para captação)
  garantiaTipo        String?     // imovel, penhor safra, aval, etc.
  garantiaDescricao   String?
  garantiaValor       Decimal?    @db.Decimal(15, 2)

  // Finalidade / captação
  finalidade          String?     // custeio, investimento, giro, etc.
  valorCaptacao       Decimal?    @db.Decimal(15, 2)  // valor a captar (se captacao)

  // Cartório / registro
  cartorioNome        String?
  cartorioRegistroNum String?
  cartorioRegistradoEm DateTime?

  // Arquivo PDF gerado
  pdfKey              String?     // S3 key
  pdfUrl              String?

  // ConectCampo fee (6% sobre valor total — aplicado apenas na Captação)
  conectcampoFeeRate  Decimal     @db.Decimal(5, 4)   @default(0.06)
  conectcampoFeeValue Decimal?    @db.Decimal(15, 2)

  // Custo de emissão (pagamento único). CPR Física = R$ 2.500
  custoEmissao        Decimal?    @db.Decimal(15, 2)

  // Assinatura eletrônica (simples, com trilha de auditoria)
  signatureStatus     String?     @default("NAO_INICIADA") // NAO_INICIADA | PENDENTE | PARCIAL | ASSINADA
  signatureProvider   String?     // interno | zapsign
  documentHash        String?     // SHA-256 do snapshot assinado
  signedSnapshot      String?     // HTML imutável capturado no momento da solicitação
  signedAt            DateTime?   // quando totalmente assinada
  emitenteSignToken   String?     @unique
  emitenteSignedAt    DateTime?
  emitenteSignIp      String?
  emitenteSignUrl     String?     // URL de assinatura (ZapSign)
  credorSignToken     String?     @unique
  credorSignedAt      DateTime?
  credorSignIp        String?
  credorSignUrl       String?     // URL de assinatura (ZapSign)
  zapsignDocToken     String?     // token do documento na ZapSign
  signedFileUrl       String?     // PDF assinado (ZapSign)

  observacoes         String?

  deletedAt           DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relations
  user                User        @relation(fields: [userId], references: [id])
  producerProfile     ProducerProfile? @relation(fields: [producerProfileId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([purpose])
  @@index([emitenteCpfCnpj])
  @@map("cpr_documents")
}

