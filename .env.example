# ============================================
# ConectCampo - Environment Variables
# ============================================

# ── Database ──────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/conectcampo?schema=public"

# ── Auth ──────────────────────────────────────
JWT_SECRET="change-me-in-production-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-in-production-min-32"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"
ADMIN_EMAILS="giovannesartor@gmail.com"

# ── API ───────────────────────────────────────
API_PORT=3001
API_PREFIX="/api/v1"
CORS_ORIGIN="http://localhost:3000"

# ── Frontend ──────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_APP_NAME="ConectCampo"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Storage (S3-compatible) ───────────────────
AWS_REGION="sa-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="conectcampo-docs"

# ── Payments ──────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_ENTERPRISE=""

# ── Email ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=conectcampodigital@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx   # App Password do Google (não a senha normal)
MAIL_FROM=conectcampodigital@gmail.com
FRONTEND_URL=https://conectcampo.digital

# ── Redis (Queue) ─────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_URL="redis://localhost:6379"

# ── Observability ─────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=""
LOG_LEVEL="debug"

# ── Encryption ────────────────────────────────
ENCRYPTION_KEY="change-me-32-chars-encryption-key!!"

# ── Integração QuantoVale (OAuth2) ────────────
# Obtido no painel do QuantoVale → Minha Conta → Aplicações OAuth2
QUANTOVALE_CLIENT_ID="qv_xxxxxxxxxxxxxxxx"
QUANTOVALE_CLIENT_SECRET="qvs_xxxxxxxxxxxxxxxx"
# URI registrada no painel do QuantoVale (produção)
QUANTOVALE_REDIRECT_URI="https://conectcampo.digital/callback"
# URLs da plataforma QuantoVale (não alterar salvo mudança de ambiente)
QUANTOVALE_AUTHORIZE_URL="https://quantovale.com.br/oauth/authorize"
QUANTOVALE_API_URL="https://api.quantovale.com.br"

# ── IA (explicação de score em linguagem natural) ──────────────────────────
# Opcional: sem a chave, a explicação usa fallback determinístico em regras.
# Com a chave, usa LLM real (Anthropic Claude) para insights personalizados.
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001

# ── ZapSign (assinatura eletrônica automática) ─────────────────────────────
# Sem a chave, a assinatura usa o fluxo interno (links próprios + trilha de auditoria).
# Com a chave, a CPR é enviada para a ZapSign e os links de assinatura são da ZapSign.
ZAPSIGN_API_KEY=
# Opcional: use a base de sandbox para testes (https://sandbox.api.zapsign.com.br/api/v1)
ZAPSIGN_BASE_URL=https://api.zapsign.com.br/api/v1
# Webhook a configurar no painel ZapSign (evento doc_signed):
#   https://SEU_DOMINIO/api/v1/cpr/zapsign/webhook

# ── Créditos de carbono (preços reais) ─────────────────────────────────────
# Preços vêm do Carbonmark (público, sem chave) + câmbio em tempo real (open.er-api.com).
# CARBON_USD_BRL é só o câmbio de fallback caso a API de câmbio esteja indisponível.
CARBON_USD_BRL=5.40

# ── Monitoramento por satélite / NDVI (Planet Insights Platform) ───────────
# Fonte 1 (preferencial) — Sentinel Hub Statistical API: valores de NDVI MEDIDOS.
#   Crie um OAuth client em https://insights.planet.com/account/#/ (OAuth Clients).
SENTINELHUB_CLIENT_ID=
SENTINELHUB_CLIENT_SECRET=
SENTINELHUB_BASE_URL=https://services.sentinel-hub.com
#
# Fonte 2 — Planet Data API: cobertura real de cenas PlanetScope (datas + nuvem).
#   Sua API key (PLAK...) em https://www.planet.com/account/#/user-settings
#   Obs.: a Planet API key NÃO funciona em services.sentinel-hub.com (por design).
PLANET_API_KEY=
PLANET_BASE_URL=https://api.planet.com
#
# Sem nenhuma das fontes acima, o NDVI usa uma série sintética sazonal de demonstração.

# ── Marketplace (custódia/escrow via ValsaPay) ─────────────────────────────
# Pagamentos do marketplace usam exclusivamente o checkout hospedado ValsaPay.
VALSA_CHECKOUT_BASE=https://pay.valsadigital.com.br
VALSA_CHECKOUT_SLUG=conectcampo
# Segredo para validar a assinatura HMAC-SHA256 do webhook da Valsa.
WEBHOOK_SECRET_VALSA=
# Dias após "enviado" para liberar o valor ao vendedor automaticamente (sem contestação).
MARKETPLACE_AUTO_CONFIRM_DAYS=7

